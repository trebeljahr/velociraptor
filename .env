# Default env values, committed. Loaded by Vite in every mode.
# Override per-developer in .env.local (gitignored).

# URL embedded into the "Challenge a friend" invite on desktop (Steam)
# game-over. Swap for the real Steam store page URL once the game is
# listed on Steam, e.g.:
#   VITE_STEAM_STORE_URL=https://store.steampowered.com/app/1234567/Raptor_Runner/
VITE_STEAM_STORE_URL=https://raptor.trebeljahr.com
