# Default env values, committed. Loaded by Vite in every mode.
# Override per-developer in .env.local (gitignored).

# URL embedded into the "Challenge a friend" clipboard invite on the
# desktop build. Swap for whichever store page you're distributing
# from — itch.io for the DRM-free channel, Steam once listed. Examples:
#   VITE_DESKTOP_STORE_URL=https://ricos-games.itch.io/raptor-runner
#   VITE_DESKTOP_STORE_URL=https://store.steampowered.com/app/1234567/Raptor_Runner/
# Back-compat: the legacy name VITE_STEAM_STORE_URL is still honoured.
VITE_DESKTOP_STORE_URL=https://raptor.trebeljahr.com
