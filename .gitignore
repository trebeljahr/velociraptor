node_modules/
dist/
dev-dist/
release/
*.log
.DS_Store
.vite/
electron/main.js
electron/preload.js
# Per-developer env overrides. Vite convention: commit .env (safe
# defaults), keep .env.local out of version control.
.env.local
.env.*.local

# ── Capacitor (mobile) ───────────────────────────────────────
# The native projects themselves (ios/App, android/*) are committed
# so that any native config changes (Info.plist, AndroidManifest, etc.)
# are tracked. Build artifacts and per-machine state are not.

# iOS build output and per-machine Xcode state
ios/App/build/
ios/App/App/public/
ios/App/Pods/
ios/DerivedData/
ios/App/App.xcodeproj/xcuserdata/
ios/App/App.xcworkspace/xcuserdata/

# Android build output and per-machine Gradle state
android/.gradle/
android/build/
android/app/build/
android/app/src/main/assets/public/
android/local.properties
android/captures/
android/.idea/

# Copied web assets — regenerated by `npx cap sync`
# (listed above per-platform for clarity)
