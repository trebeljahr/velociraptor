{
  "name": "raptor-runner",
  "private": true,
  "version": "1.0.0",
  "description": "A pixel-art homage to the Chrome 'No Internet' dinosaur game, with a full day/night cycle and a starry sky.",
  "type": "module",
  "main": "electron/main.js",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "electron:compile": "tsc electron/main.ts electron/preload.ts --outDir electron --module CommonJS --moduleResolution node --esModuleInterop --target ES2022 --skipLibCheck",
    "electron:dev": "npm run electron:compile && NODE_ENV=development electron .",
    "electron:build": "npm run build && npm run electron:compile && electron-builder",
    "electron:preview": "npm run build && npm run electron:compile && electron ."
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.0.0",
    "@types/node": "^20.11.0",
    "electron": "^33.0.0",
    "electron-builder": "^25.0.0",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.4.0",
    "vite": "^5.2.0",
    "vite-plugin-pwa": "^0.19.0"
  },
  "build": {
    "appId": "com.trebeljahr.raptor-runner",
    "productName": "Raptor Runner",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/main.js",
      "electron/preload.js",
      "public/assets/icon-512.png"
    ],
    "mac": {
      "target": "dmg",
      "icon": "public/assets/icon-512.png"
    },
    "win": {
      "target": "nsis",
      "icon": "public/assets/icon-512.png"
    },
    "linux": {
      "target": "AppImage",
      "icon": "public/assets/icon-512.png"
    }
  }
}
