# Copy to android/keystore.properties and fill in real values.
# keystore.properties is gitignored — the private file lives only on
# your machine + a password-manager backup. Losing this file + its
# passwords means you can never update the Raptor Runner app on Play
# Store again (the store rejects any APK signed with a different key).
storeFile=../release.keystore
storePassword=CHANGE_ME
keyAlias=raptor-runner
keyPassword=CHANGE_ME
